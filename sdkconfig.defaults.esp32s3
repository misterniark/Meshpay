# Configuration spécifique ESP32-S3 (Waveshare ESP32-S3-Touch-LCD-1.47)
CONFIG_IDF_TARGET="esp32s3"
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y

# --- Console serie sur USB-Serial-JTAG (USB-C natif, GPIO 19/20) ---
# Obligatoire : libere UART0 / GPIO 43-44, utilises pour cabler le
# module LoRa Wio-E5. Sans ce reglage, la console defaulterait sur
# UART0 et entrerait en conflit direct avec le Wio-E5.
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y

# --- PSRAM (8MB octal SPI) ---
CONFIG_ESP32S3_SPIRAM_SUPPORT=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y

# --- Secure Boot V2 (PRODUCTION UNIQUEMENT) ---
# ESP32-S3 supporte nativement Secure Boot V2 (pas de restriction de revision).
# Non active par defaut car necessite :
#   1. Une cle RSA-3072 generee avec :
#      espsecure.py generate_signing_key --version 2 secure_boot_key.pem
#   2. Brulage irreversible des eFuses au premier boot
#
# Pour activer, decommenter :
# CONFIG_SECURE_BOOT=y
# CONFIG_SECURE_BOOT_V2_ENABLED=y
# CONFIG_SECURE_BOOT_BUILD_SIGNED_BINARIES=y

# --- Gestion de l'energie (feature 13) ---
# Active esp_pm pour le CPU frequency scaling en mode ECO.
# Phase 1 : frequency scaling seul (pas de light sleep). Le light sleep
# (CONFIG_FREERTOS_USE_TICKLESS_IDLE) viendra en Phase 2.
CONFIG_PM_ENABLE=y

# --- LoRa : la carte Waveshare (ESP32-S3) est equipee du module Core1262 ---
CONFIG_MESHPAY_LORA_DRIVER_CORE1262=y
